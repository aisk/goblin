# continue skips to the next iteration of the enclosing loop

# In a while loop (condition is re-evaluated after continue)
var i = 0
while i < 10 {
    i = i + 1
    if i == 3 {
        continue
    }
    if i == 7 {
        break
    }
    print(i)
}

# In a for-in loop
for x in [1, 2, 3, 4, 5] {
    if x == 3 {
        continue
    }
    print(x)
}
