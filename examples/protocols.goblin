# User-defined types can customize built-in protocols by defining methods with
# conventional __-prefixed names: operators (__add/__sub/...), comparison
# (__cmp), string and truthiness conversion (__str/__bool), iteration (__iter),
# and indexing (__getitem/__setitem).

type Vector(x, y) {
    func __add(self, other) {
        return Vector(self.x + other.x, self.y + other.y)
    }
    func __sub(self, other) {
        return Vector(self.x - other.x, self.y - other.y)
    }
    # __cmp returns -1, 0 or 1; it powers ==, !=, <, >, <=, >=
    func __cmp(self, other) {
        var a = self.x + self.y
        var b = other.x + other.y
        if a < b {
            return -1
        }
        if a > b {
            return 1
        }
        return 0
    }
    func __str(self) {
        return "Vector(" + Str(self.x) + ", " + Str(self.y) + ")"
    }
}

var v = Vector(1, 2)
var w = Vector(3, 4)

print(v + w)
print(w - v)
print(v)

print(v == v)
print(v == w)
print(v < w)
print(v > w)
print(v <= w)

# A type that opts into iteration and indexing.
type Grid(cells) {
    func __getitem(self, i) {
        return self.cells[i]
    }
    func __setitem(self, i, value) {
        self.cells[i] = value
    }
    func __iter(self) {
        return self.cells
    }
    func size(self) {
        return self.cells.size()
    }
}

var g = Grid([10, 20, 30])
print(g[0])
g[1] = 99
print(g[1])
for x in g {
    print(x)
}
print(g.size())

# A type that defines none of these protocols keeps the defaults: it is always
# truthy, so it takes the `if` branch here.
type Opaque() {
}
var o = Opaque()
if o {
    print("opaque is truthy")
}
