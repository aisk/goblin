import "random"

# int / intn return integers, float returns a float
print(random.int().constructor == Int)
print(random.intn(100).constructor == Int)
print(random.float().constructor == Float)

# intn(1) can only ever be 0
print(random.intn(1))

# float() is always within [0.0, 1.0)
print(random.float() >= 0.0)
print(random.float() < 1.0)
